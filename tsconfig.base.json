{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": [
        "core/*"
      ],
      "@shared/*": [
        "packages/shared/src/*"
      ],
      "@thejatcms/sdk": [
        "packages/sdk/src/index.ts"
      ],
      "@thejatcms/sdk/*": [
        "packages/sdk/src/*"
      ]
    }
  }
}